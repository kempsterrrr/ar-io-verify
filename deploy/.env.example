# ar.io Verify — Standalone Deployment
#
# Copy this file to .env and adjust values for your setup.

# Docker image (build locally or use a registry image)
VERIFY_IMAGE=ar-io-verify:local

# Gateway envoy container hostname on ar-io-network
# Find it with: docker ps --filter network=ar-io-network --format '{{.Names}}'
GATEWAY_URL=http://ar-io-node-envoy-1:3000

# Gateway hostname (used in attestation payload)
GATEWAY_HOST=vilenarios.com

# Public port for the verify UI and API
VERIFY_PORT=4001

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Environment
NODE_ENV=production

# Attestation signing (optional — leave empty to disable)
# Host path to Arweave JWK wallet file for signing verification certificates
WALLET_FILE=
