{
  "name": "ar-io-verify",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "pnpm --filter @ar-io/verify-server run build && pnpm --filter verify-web run build",
    "dev": "pnpm --filter @ar-io/verify-server run dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "pnpm --filter @ar-io/verify-server run test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.15.0"
}
